{
  "name": "@bounded-systems/seam-check",
  "version": "0.1.0",
  "description": "Declare and prove a package's seam claim — its allowed imports and zero ambient authority — with a coverage meta-check that makes every package declare one",
  "bounded": {
    "tagline": "Declare and prove a package's seam claim — its allowed imports and zero ambient authority — with a coverage meta-check that makes every package declare one",
    "kind": "room"
  },
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bounded-systems/seam-check.git"
  },
  "homepage": "https://github.com/bounded-systems/seam-check#readme",
  "bugs": {
    "url": "https://github.com/bounded-systems/seam-check/issues"
  },
  "keywords": [
    "seam",
    "capability",
    "extractability",
    "allowlist",
    "ambient-authority",
    "conformance",
    "claims",
    "object-capability"
  ],
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "bun run build"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "typescript": "^6.0.3"
  }
}
